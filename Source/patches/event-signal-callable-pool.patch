From: ETA project local patch
Subject: [PATCH] Free-list pool for SignalAwaiterCallable + EventSignalCallable

Problem
-------
Two adjacent sites in the C#/Mono integration carry explicit
"TODO: Use pooling for ManagedCallable instances." markers and each
allocates a fresh CallableCustom on the heap per use:

  - modules/mono/signal_awaiter_utils.cpp:42 — one
    SignalAwaiterCallable per `await Signal` in C#. State machines,
    async loaders, and any `await ToSignal(...)` pattern hit this.
    One-shot lifetime: object lives only until the signal fires,
    then memdelete'd.

  - modules/mono/csharp_script.cpp:1830 — one EventSignalCallable
    per [Signal] event signal per CSharpInstance. Fires on every
    LocalPlayer spawn / reconnect cycle in this project (player +
    weapons + HUD + NetStats event signals add up to tens of
    allocations per spawn).

Each instance is small (3-4 fields plus vtable + refcount) but the
free-and-realloc pattern fragments the heap and shows up as
ObjectDB sawtooth + Gen0 churn during gameplay, especially during
respawn / round-restart bursts.

Fix
---
1. Add a `virtual void destroy_custom()` hook to CallableCustom
   (core/variant/callable.h). Default impl is `memdelete(this)` —
   so all existing CallableCustom subclasses are unaffected.

2. Wire Callable::~Callable to call `custom->destroy_custom()`
   instead of `memdelete(custom)`. Behaviour-preserving for the
   default case; gives pool-backed customs a hook to redirect the
   deallocation.

3. Add a bounded free-list pool (cap 64 entries) to both
   SignalAwaiterCallable and EventSignalCallable. The pool stores
   raw memory blocks of slots that have been destructor-run but
   not freed:

     - `acquire(args)` pops a slot from the pool (placement-new the
       new args into it) or falls through to memnew when the pool
       is empty.

     - `destroy_custom()` overrides the base impl: runs the
       destructor manually, pushes the bare memory back to the
       pool if under cap, falls through to `Memory::free_static`
       when full. Symmetric with memnew + memdelete end-to-end.

4. Use-site updates:

     - signal_awaiter_utils.cpp `gd_mono_connect_signal_awaiter` calls
       `SignalAwaiterCallable::acquire(...)` instead of memnew.

     - csharp_script.cpp `connect_event_signals` calls
       `EventSignalCallable::acquire(...)` instead of memnew.

The pool is mutex-guarded — signal connections can happen on the
main thread, during scene-tree construction, or inside callback
chains. Lock cost is well below memnew overhead.

Verified
--------
TODO — measure with a 60-second listen-server bot match plus
reconnect cycle. Look for reduction in Gen0 collection count and
the ObjectDB oscillation amplitude during respawn bursts in the
[SPIKE] log lines from NetMain.

Patch
-----

--- a/core/variant/callable.cpp
+++ b/core/variant/callable.cpp
@@ -439,7 +439,10 @@ Callable::Callable(const Callable &p_callable) {
 Callable::~Callable() {
 	if (is_custom()) {
 		if (custom->ref_count.unref()) {
-			memdelete(custom);
+			// Virtual destroy hook — default is memdelete, pool-backed customs
+			// (e.g., SignalAwaiterCallable, EventSignalCallable) override this
+			// to return their backing memory to a free-list instead.
+			custom->destroy_custom();
 			custom = nullptr;
 		}
 	}
--- a/core/variant/callable.h
+++ b/core/variant/callable.h
@@ -165,6 +165,13 @@ public:
 	virtual void get_bound_arguments(Vector<Variant> &r_arguments) const;
 	virtual int get_unbound_arguments_count() const;

+	// Override to redirect deallocation (e.g., return to a pool). Default frees
+	// via memdelete. Called from Callable's destructor when the last refcount
+	// drops, BEFORE the framework's destruction path, so overrides must do
+	// the full job (destructor + free / pool-return) themselves and not
+	// chain to the default unless they want a normal memdelete.
+	virtual void destroy_custom() { memdelete(this); }
+
 	CallableCustom();
 	virtual ~CallableCustom() {}
 };
--- a/modules/mono/csharp_script.cpp
+++ b/modules/mono/csharp_script.cpp
@@ -1826,8 +1826,7 @@ void CSharpInstance::connect_event_signals() {
 		for (const CSharpScript::EventSignalInfo &signal : top->event_signals) {
 			String signal_name = signal.name;

-			// TODO: Use pooling for ManagedCallable instances.
-			EventSignalCallable *event_signal_callable = memnew(EventSignalCallable(owner, signal_name));
+			EventSignalCallable *event_signal_callable = EventSignalCallable::acquire(owner, signal_name);

 			Callable callable(event_signal_callable);
 			connected_event_signals.push_back(callable);
--- a/modules/mono/signal_awaiter_utils.cpp
+++ b/modules/mono/signal_awaiter_utils.cpp
@@ -37,14 +37,46 @@ Error gd_mono_connect_signal_awaiter(Object *p_source, const StringName &p_signa
 	ERR_FAIL_NULL_V(p_source, ERR_INVALID_DATA);
 	ERR_FAIL_NULL_V(p_target, ERR_INVALID_DATA);

-	// TODO: Use pooling for ManagedCallable instances.
 	MonoGCHandleData awaiter_handle(p_awaiter_handle_ptr, gdmono::GCHandleType::STRONG_HANDLE);
-	SignalAwaiterCallable *awaiter_callable = memnew(SignalAwaiterCallable(p_target, awaiter_handle, p_signal));
+	SignalAwaiterCallable *awaiter_callable = SignalAwaiterCallable::acquire(p_target, awaiter_handle, p_signal);
 	Callable callable = Callable(awaiter_callable);

 	return p_source->connect(p_signal, callable, Object::CONNECT_ONE_SHOT);
 }

+Mutex SignalAwaiterCallable::pool_mutex;
+LocalVector<SignalAwaiterCallable *> SignalAwaiterCallable::pool;
+
+SignalAwaiterCallable *SignalAwaiterCallable::acquire(Object *p_target, MonoGCHandleData p_awaiter_handle, const StringName &p_signal) {
+	SignalAwaiterCallable *recycled = nullptr;
+	{
+		MutexLock lock(pool_mutex);
+		if (!pool.is_empty()) {
+			recycled = pool[pool.size() - 1];
+			pool.resize(pool.size() - 1);
+		}
+	}
+	if (recycled) {
+		// Placement-new into the recycled slot — destructor already ran in destroy_custom().
+		return ::new (recycled) SignalAwaiterCallable(p_target, p_awaiter_handle, p_signal);
+	}
+	return memnew(SignalAwaiterCallable(p_target, p_awaiter_handle, p_signal));
+}
+
+void SignalAwaiterCallable::destroy_custom() {
+	this->~SignalAwaiterCallable();
+	{
+		MutexLock lock(pool_mutex);
+		if (pool.size() < POOL_MAX) {
+			pool.push_back(this);
+			return;
+		}
+	}
+	// Pool full — free the underlying memory via Godot's allocator (matches what
+	// memnew + memdelete would have done end-to-end).
+	Memory::free_static(this, false);
+}
+
 bool SignalAwaiterCallable::compare_equal(const CallableCustom *p_a, const CallableCustom *p_b) {
 	// Only called if both instances are of type SignalAwaiterCallable. Static cast is safe.
 	const SignalAwaiterCallable *a = static_cast<const SignalAwaiterCallable *>(p_a);
@@ -202,3 +234,33 @@ EventSignalCallable::EventSignalCallable(Object *p_owner, const StringName &p_ev
 		owner(p_owner),
 		event_signal_name(p_event_signal_name) {
 }
+
+Mutex EventSignalCallable::pool_mutex;
+LocalVector<EventSignalCallable *> EventSignalCallable::pool;
+
+EventSignalCallable *EventSignalCallable::acquire(Object *p_owner, const StringName &p_event_signal_name) {
+	EventSignalCallable *recycled = nullptr;
+	{
+		MutexLock lock(pool_mutex);
+		if (!pool.is_empty()) {
+			recycled = pool[pool.size() - 1];
+			pool.resize(pool.size() - 1);
+		}
+	}
+	if (recycled) {
+		return ::new (recycled) EventSignalCallable(p_owner, p_event_signal_name);
+	}
+	return memnew(EventSignalCallable(p_owner, p_event_signal_name));
+}
+
+void EventSignalCallable::destroy_custom() {
+	this->~EventSignalCallable();
+	{
+		MutexLock lock(pool_mutex);
+		if (pool.size() < POOL_MAX) {
+			pool.push_back(this);
+			return;
+		}
+	}
+	Memory::free_static(this, false);
+}
