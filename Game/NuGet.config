<?xml version="1.0" encoding="utf-8"?>
<!--
  Project-scoped NuGet config. Without this, NuGet falls back to the global
  C:\Users\<user>\AppData\Roaming\NuGet\NuGet.Config which only lists nuget.org -
  it will then resolve <PackageReference Include="GodotSharp" Version="4.6.3" /> by
  DOWNLOADING the vanilla public GodotSharp 4.6.3 from nuget.org, completely
  ignoring the patched .nupkg files that build-engine.cmd ships into
  Engine/GodotSharp/Tools/nupkgs/. The symptom is `CS0246: type X not found` for
  any type added by our local engine patches (e.g. PhysicsRayQueryResult3D), even
  though Engine/GodotSharp/Api/.../GodotSharp.dll has the symbol.

  Resolution rules below:
  - packageSources lists BOTH the local patched feed and nuget.org. Local first
    so plain "any source" resolution prefers it.
  - packageSourceMapping HARD-pins every Godot.* / GodotSharp* package to the
    local feed. Even if nuget.org is also configured, NuGet now refuses to look
    there for those package IDs - the patched version always wins.
  - LiteNetLib (and any future external dep) is mapped to nuget.org via the
    wildcard pattern.

  Path is relative to this NuGet.config location: ../Engine/GodotSharp/Tools/nupkgs
  resolves to D:\Godot\Engine\GodotSharp\Tools\nupkgs which is what build-engine.cmd
  populates after every engine rebuild.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="GodotPatched" value="../Engine/GodotSharp/Tools/nupkgs" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="GodotPatched">
      <package pattern="GodotSharp*" />
      <package pattern="Godot.NET.Sdk" />
      <package pattern="Godot.SourceGenerators*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
