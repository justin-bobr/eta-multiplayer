###############################################################################
# Workspace-wide gitignore - siblings of Game/ that should NOT be versioned.
# Game/ has its own .gitignore for project-internal artefacts (.godot/, .mono/).
###############################################################################

# Stock Godot binaries + custom-built export templates. Big (~170MB editor,
# ~80MB per template) and platform-specific - user re-downloads / re-builds.
Engine/

# Build outputs (client.exe + server.exe + bundled native AOT runtime + PCK).
# Built fresh by build-client.cmd / build-server.cmd whenever needed.
Export/

# Random downloads parked next to Game/ (assets, reference material, etc.).
Downloads/

# Godot engine source-tree for build-engine.cmd's scons compilation.
# Cloned from godotengine/godot - not part of THIS project's history.
Source/

# Generic OS / IDE noise just in case the workspace root is opened as a folder.
Thumbs.db
desktop.ini
.DS_Store
.claude
*.blend