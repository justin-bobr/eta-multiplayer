#!/usr/bin/env bash


set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

CSPROJ="Game/vantix.csproj"
XML="Game/.godot/mono/temp/bin/Debug/vantix.xml"
OUT="Docs"

# Skip cleanly if the toolchain is missing — don't block a push over a missing SDK.
if ! command -v dotnet >/dev/null 2>&1; then
  echo "pre-push: 'dotnet' not found, skipping API-doc regeneration." >&2
  exit 0
fi
if ! command -v python >/dev/null 2>&1 && ! command -v python3 >/dev/null 2>&1; then
  echo "pre-push: 'python' not found, skipping API-doc regeneration." >&2
  exit 0
fi
PY="$(command -v python || command -v python3)"

echo "pre-push: building $CSPROJ and regenerating API docs..."
dotnet build "$CSPROJ" -c Debug -v quiet --nologo >/dev/null

if [ ! -f "$XML" ]; then
  echo "pre-push: expected XML doc at $XML but it was not produced. Is <GenerateDocumentationFile> set?" >&2
  exit 1
fi

"$PY" Scripts/gen_api_md.py "$XML" "$OUT" >/dev/null

if ! git diff --quiet -- "$OUT"; then
  echo >&2
  echo "  📚 API docs were out of date and have been regenerated under $OUT/." >&2
  echo "     Review, commit them, then push again:" >&2
  echo >&2
  echo "       git add $OUT && git commit -m \"docs: regenerate API reference\"" >&2
  echo "       git push" >&2
  echo >&2
  exit 1
fi

echo "pre-push: API docs are up to date."
exit 0
